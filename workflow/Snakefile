"""
Assembly Workflow
A Snakemake workflow for genome assembly, annotation, and evaluation

Annotation module:
1. Filter assembly contigs by length and reference alignment
2. Create chain files for coordinate conversion
3. Liftoff gene annotation from GRCh38
4. TRF-mod tandem repeat annotation
5. DNA-NN alpha satellite annotation
6. RepeatMasker repeat annotation
7. Segdup segmental duplication annotation
8. CenSat centromeric satellite annotation

Evaluation module:
1. Flagger - misassembly detection using coverage
2. Inspector - structural and small-scale error detection
3. Nucflag - nucleotide-level misassembly detection
4. Merqury - k-mer based QV estimation
5. YAK - base-level accuracy estimation
6. T2T - telomere-to-telomere contig identification
7. Compleasm - BUSCO gene completeness assessment
"""

import pandas as pd
from snakemake.utils import min_version

# Minimum Snakemake version
min_version("7.0")


# Load rules
include: "rules/commons.smk"
include: "rules/process.smk"


BASE = config["output"]["base"]


# ====================================================================
# Per-module sample sets (driven by the run_modules column).
# A sample only contributes the outputs of the modules listed in run_modules
# (default: all modules when the column is absent/empty).
# ====================================================================
ASSEMBLY_SAMPLES = [s for s in samples.index if should_run_assembly(s)]
ANNOTATION_SAMPLES = [s for s in samples.index if should_run_annotation(s)]
EVALUATION_SAMPLES = [s for s in samples.index if should_run_evaluation(s)]


def _assemblers(sample_list):
    return [samples.loc[s, "assembler"] for s in sample_list]


def _zip_expand(patterns, sample_list):
    """expand `patterns` over paired (assembler, sample) for the given samples."""
    return expand(patterns, zip,
                  assembler=_assemblers(sample_list), sample=sample_list)


# Output patterns per module (over {sample}/{assembler} wildcards).
ASSEMBLY_PATTERNS = [
    BASE + "/{sample}/assembly/filter/{assembler}/{sample}.filt.fa",
    BASE + "/{sample}/assembly/filter/{assembler}/{sample}.hap1.filt.fa",
    BASE + "/{sample}/assembly/filter/{assembler}/{sample}.hap2.filt.fa",
]

ANNOTATION_PATTERNS = [
    BASE + "/{sample}/annotation/chain_files/{assembler}/{sample}_to_chm13.chain",
    BASE + "/{sample}/annotation/chain_files/{assembler}/{sample}_to_GRCh38.chain",
    BASE + "/{sample}/annotation/liftoff/{assembler}/{sample}.Ensembl_GRCh38.liftoff.bed.gz",
    BASE + "/{sample}/annotation/trf_mod/{assembler}/{sample}.trf-mod.bed",
    BASE + "/{sample}/annotation/dna_nn/{assembler}/{sample}.hap1_dna-brnn.bed.gz",
    BASE + "/{sample}/annotation/dna_nn/{assembler}/{sample}.hap2_dna-brnn.bed.gz",
    BASE + "/{sample}/annotation/repeatmasker/{assembler}/{sample}.rmsk.bed.gz",
    BASE + "/{sample}/annotation/repeatmasker/{assembler}/{sample}.LINE1.bed.gz",
    BASE + "/{sample}/annotation/segdup/{assembler}/{sample}.filtered.bed.gz",
    BASE + "/{sample}/annotation/censat/{assembler}/{sample}.cenSat.bed.gz",
    BASE + "/{sample}/annotation/censat/{assembler}/{sample}.active.centromeres.bed.gz",
]

# Evaluation outputs are grouped by the read type they require, so a sample is
# only asked for the evaluations its input data can support (Step 3).
# Assembly-only (no reads needed):
EVAL_ASSEMBLY_PATTERNS = [
    BASE + "/{sample}/evaluation/t2t/{assembler}/t2t_contigs_hap1.txt",
    BASE + "/{sample}/evaluation/compleasm/{assembler}/summary_results.txt",
]
# Require HiFi reads:
EVAL_HIFI_PATTERNS = [
    BASE + "/{sample}/evaluation/flagger/{assembler}/hifi/summary_flagger_results.txt",
    BASE + "/{sample}/evaluation/inspector/{assembler}/HiFi/summary_results.txt",
    BASE + "/{sample}/evaluation/nucflag/{assembler}/summary_results.txt",
    BASE + "/{sample}/evaluation/yak/{assembler}/{sample}.hap1.pb.yak.qv.txt",
]
# Require ONT reads:
EVAL_ONT_PATTERNS = [
    BASE + "/{sample}/evaluation/flagger/{assembler}/ont/summary_flagger_results.txt",
]


def assembly_targets():
    return _zip_expand(ASSEMBLY_PATTERNS, ASSEMBLY_SAMPLES)


def annotation_targets():
    return _zip_expand(ANNOTATION_PATTERNS, ANNOTATION_SAMPLES)


def evaluation_targets():
    out = list(_zip_expand(EVAL_ASSEMBLY_PATTERNS, EVALUATION_SAMPLES))
    # Read-type-gated evaluations.
    out += _zip_expand(EVAL_HIFI_PATTERNS,
                       [s for s in EVALUATION_SAMPLES if has_hifi(s)])
    out += _zip_expand(EVAL_ONT_PATTERNS,
                       [s for s in EVALUATION_SAMPLES if has_ont(s)])
    # Data-gated evaluations: only samples that carry the extra data.
    merqury_s = [s for s in EVALUATION_SAMPLES if col_value(s, "illumina_r1")]
    out += _zip_expand(
        BASE + "/{sample}/evaluation/merqury/{assembler}/out.qv", merqury_s)
    pstools_s = [s for s in EVALUATION_SAMPLES if col_value(s, "hic_r1")]
    out += _zip_expand(
        BASE + "/{sample}/evaluation/haplotype_switch/{assembler}/pstools/phase_error_output.txt", pstools_s)
    trio_s = [s for s in EVALUATION_SAMPLES if col_value(s, "pat_r1")]
    out += _zip_expand(
        BASE + "/{sample}/evaluation/haplotype_switch/{assembler}/yak_trioeval/paternal.yak_phasing.txt", trio_s)
    return out


# ====================================================================
# Target rules. `all` is the default and aggregates each sample's enabled
# modules; `assembly` / `annotation` / `evaluation` run a single module.
# ====================================================================
rule all:
    input:
        assembly_targets() + annotation_targets() + evaluation_targets()


rule assembly:
    input:
        assembly_targets()


# Target rule: annotation only
rule annotation:
    input:
        annotation_targets()


# Target rule: evaluation only
rule evaluation:
    input:
        evaluation_targets()


# Rule to print DAG
rule dag:
    shell:
        """
        snakemake --dag | dot -Tpdf > dag.pdf
        """


# Rule to print workflow summary
rule summary:
    run:
        print("Assembly Workflow (Annotation + Evaluation)")
        print("=" * 50)
        print(f"Number of samples: {len(samples)}")
        print(f"Samples: {', '.join(samples.index)}")
        print(f"Assemblers: {', '.join(samples['assembler'].unique())}")
        print("")
        print(f"  run_modules -> assembly: {len(ASSEMBLY_SAMPLES)}, "
              f"annotation: {len(ANNOTATION_SAMPLES)}, evaluation: {len(EVALUATION_SAMPLES)}")
        print("")
        print("Available targets (each restricted by the run_modules column):")
        print("  - assembly:   Run assembly + filter module only")
        print("  - annotation: Run annotation module only")
        print("  - evaluation: Run evaluation module only")
        print("  - all: Run each sample's enabled modules (default)")
        print("=" * 50)
